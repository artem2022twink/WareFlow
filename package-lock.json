{
  "name": "wareflow",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "wareflow",
      "version": "0.1.0",
      "license": "ISC",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "devDependencies": {
        "typescript": "^6.0.3"
      }
    },
    "apps/backend": {
      "name": "@wareflow/backend",
      "version": "0.1.0"
    },
    "apps/frontend": {
      "name": "@wareflow/frontend",
      "version": "0.1.0"
    },
    "node_modules/@wareflow/backend": {
      "resolved": "apps/backend",
      "link": true
    },
    "node_modules/@wareflow/frontend": {
      "resolved": "apps/frontend",
      "link": true
    },
    "node_modules/@wareflow/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/typescript": {
      "version": "6.0.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-6.0.3.tgz",
      "integrity": "sha512-y2TvuxSZPDyQakkFRPZHKFm+KKVqIisdg9/CZwm9ftvKXLP8NRWj38/ODjNbr43SsoXqNuAisEf1GdCxqWcdBw==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/shared": {
      "name": "@wareflow/shared",
      "version": "0.1.0"
    }
  }
}
