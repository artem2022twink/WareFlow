{
  "name": "wareflow",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "wareflow",
      "version": "0.1.0",
      "license": "ISC",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/backend": {
      "name": "@wareflow/backend",
      "version": "0.1.0"
    },
    "apps/frontend": {
      "name": "@wareflow/frontend",
      "version": "0.1.0"
    },
    "node_modules/@wareflow/backend": {
      "resolved": "apps/backend",
      "link": true
    },
    "node_modules/@wareflow/frontend": {
      "resolved": "apps/frontend",
      "link": true
    },
    "node_modules/@wareflow/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "packages/shared": {
      "name": "@wareflow/shared",
      "version": "0.1.0"
    }
  }
}
